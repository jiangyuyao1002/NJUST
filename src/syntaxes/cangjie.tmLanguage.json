{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Cangjie",
	"scopeName": "source.cangjie",
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#strings" },
		{ "include": "#characters" },
		{ "include": "#numbers" },
		{ "include": "#annotations" },
		{ "include": "#keywords" },
		{ "include": "#types" },
		{ "include": "#declarations" },
		{ "include": "#operators" },
		{ "include": "#punctuation" },
		{ "include": "#raw-identifiers" }
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.cangjie",
					"match": "//.*$"
				},
				{
					"name": "comment.block.cangjie",
					"begin": "/\\*",
					"end": "\\*/",
					"patterns": [
						{ "include": "#comments" }
					]
				}
			]
		},

		"strings": {
			"patterns": [
				{ "include": "#string-triple-double-quoted" },
				{ "include": "#string-triple-single-quoted" },
				{ "include": "#string-raw-triple-hash" },
				{ "include": "#string-raw-double-hash" },
				{ "include": "#string-raw-single-hash" },
				{ "include": "#string-double-quoted" },
				{ "include": "#string-single-quoted" },
				{ "include": "#byte-literal" }
			]
		},

		"string-triple-double-quoted": {
			"name": "string.quoted.triple.double.cangjie",
			"begin": "\"\"\"",
			"end": "\"\"\"",
			"patterns": [
				{ "include": "#string-interpolation" },
				{ "include": "#escape-sequences" }
			]
		},

		"string-triple-single-quoted": {
			"name": "string.quoted.triple.single.cangjie",
			"begin": "'''",
			"end": "'''",
			"patterns": [
				{ "include": "#string-interpolation" },
				{ "include": "#escape-sequences" }
			]
		},

		"string-raw-triple-hash": {
			"name": "string.quoted.raw.triple-hash.cangjie",
			"begin": "###\"",
			"end": "\"###"
		},

		"string-raw-double-hash": {
			"name": "string.quoted.raw.double-hash.cangjie",
			"begin": "##\"",
			"end": "\"##"
		},

		"string-raw-single-hash": {
			"name": "string.quoted.raw.single-hash.cangjie",
			"begin": "#\"",
			"end": "\"#"
		},

		"string-double-quoted": {
			"name": "string.quoted.double.cangjie",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{ "include": "#string-interpolation" },
				{ "include": "#escape-sequences" }
			]
		},

		"string-single-quoted": {
			"name": "string.quoted.single.cangjie",
			"begin": "'",
			"end": "'",
			"patterns": [
				{ "include": "#string-interpolation" },
				{ "include": "#escape-sequences" }
			]
		},

		"string-interpolation": {
			"name": "meta.interpolation.cangjie",
			"begin": "\\$\\{",
			"end": "\\}",
			"beginCaptures": {
				"0": { "name": "punctuation.section.interpolation.begin.cangjie" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.section.interpolation.end.cangjie" }
			},
			"patterns": [
				{ "include": "source.cangjie" }
			]
		},

		"escape-sequences": {
			"patterns": [
				{
					"name": "constant.character.escape.unicode.cangjie",
					"match": "\\\\u\\{[0-9a-fA-F]{1,8}\\}"
				},
				{
					"name": "constant.character.escape.cangjie",
					"match": "\\\\[0nrtf\\\\'\"`$]"
				}
			]
		},

		"characters": {
			"patterns": [
				{
					"name": "string.quoted.rune.cangjie",
					"match": "r(\"(?:[^\"\\\\]|\\\\[0nrtf\\\\'\"`$]|\\\\u\\{[0-9a-fA-F]{1,8}\\})\")",
					"captures": {
						"0": { "name": "string.quoted.rune.cangjie" }
					}
				},
				{
					"name": "string.quoted.rune.cangjie",
					"match": "r('(?:[^'\\\\]|\\\\[0nrtf\\\\'\"`$]|\\\\u\\{[0-9a-fA-F]{1,8}\\})')",
					"captures": {
						"0": { "name": "string.quoted.rune.cangjie" }
					}
				}
			]
		},

		"byte-literal": {
			"name": "constant.character.byte.cangjie",
			"match": "b'(?:[^'\\\\]|\\\\[0nrtf\\\\'\"`$]|\\\\u\\{[0-9a-fA-F]{1,2}\\})'"
		},

		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.hex.float.cangjie",
					"match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*(?:\\.[0-9a-fA-F][0-9a-fA-F_]*)?[pP][+-]?[0-9][0-9_]*(?:f16|f32|f64)?\\b"
				},
				{
					"name": "constant.numeric.hex.cangjie",
					"match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*(?:i8|i16|i32|i64|u8|u16|u32|u64)?\\b"
				},
				{
					"name": "constant.numeric.binary.cangjie",
					"match": "\\b0[bB][01][01_]*(?:i8|i16|i32|i64|u8|u16|u32|u64)?\\b"
				},
				{
					"name": "constant.numeric.octal.cangjie",
					"match": "\\b0[oO][0-7][0-7_]*(?:i8|i16|i32|i64|u8|u16|u32|u64)?\\b"
				},
				{
					"name": "constant.numeric.float.cangjie",
					"match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][+-]?[0-9][0-9_]*)?(?:f16|f32|f64)?\\b"
				},
				{
					"name": "constant.numeric.float.cangjie",
					"match": "\\b[0-9][0-9_]*[eE][+-]?[0-9][0-9_]*(?:f16|f32|f64)?\\b"
				},
				{
					"name": "constant.numeric.float.cangjie",
					"match": "\\.[0-9][0-9_]*(?:[eE][+-]?[0-9][0-9_]*)?(?:f16|f32|f64)?\\b"
				},
				{
					"name": "constant.numeric.decimal.cangjie",
					"match": "\\b[0-9][0-9_]*(?:i8|i16|i32|i64|u8|u16|u32|u64|f16|f32|f64)?\\b"
				}
			]
		},

		"annotations": {
			"patterns": [
				{
					"match": "(@)(\\w+)",
					"captures": {
						"1": { "name": "punctuation.definition.annotation.cangjie" },
						"2": { "name": "entity.name.type.annotation.cangjie" }
					}
				}
			]
		},

		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.cangjie",
					"match": "\\b(if|else|for|while|match|case|do|break|continue|return|throw|try|catch|finally|in|is|as|where)\\b"
				},
				{
					"name": "storage.type.cangjie",
					"match": "\\b(class|struct|interface|enum|func|init|extend|type|macro|prop|operator)\\b"
				},
				{
					"name": "storage.type.variable.cangjie",
					"match": "\\b(let|var|const)\\b"
				},
				{
					"name": "storage.modifier.cangjie",
					"match": "\\b(public|private|protected|internal|open|abstract|sealed|override|static|mut|unsafe|foreign|redef|synchronized)\\b"
				},
				{
					"name": "keyword.other.cangjie",
					"match": "\\b(import|package|spawn|quote|main|super|this|This)\\b"
				},
				{
					"name": "constant.language.boolean.cangjie",
					"match": "\\b(true|false)\\b"
				},
				{
					"name": "constant.language.cangjie",
					"match": "\\b(Nothing)\\b"
				}
			]
		},

		"types": {
			"patterns": [
				{
					"name": "support.type.primitive.cangjie",
					"match": "\\b(Int8|Int16|Int32|Int64|IntNative|UInt8|UInt16|UInt32|UInt64|UIntNative|Float16|Float32|Float64|Bool|Rune|Unit|String|VArray|Byte|Array|Option|Range)\\b"
				},
				{
					"name": "entity.name.type.cangjie",
					"match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
				}
			]
		},

		"declarations": {
			"patterns": [
				{
					"match": "\\b(class|struct|interface|enum|extend)\\s+([A-Z]\\w*)",
					"captures": {
						"1": { "name": "storage.type.cangjie" },
						"2": { "name": "entity.name.type.class.cangjie" }
					}
				},
				{
					"match": "\\b(func)\\s+([a-zA-Z_]\\w*)",
					"captures": {
						"1": { "name": "storage.type.cangjie" },
						"2": { "name": "entity.name.function.cangjie" }
					}
				},
				{
					"match": "\\b(macro)\\s+([a-zA-Z_]\\w*)",
					"captures": {
						"1": { "name": "storage.type.cangjie" },
						"2": { "name": "entity.name.function.macro.cangjie" }
					}
				}
			]
		},

		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.arrow.cangjie",
					"match": "=>|->|<-"
				},
				{
					"name": "keyword.operator.type.cangjie",
					"match": "<:"
				},
				{
					"name": "keyword.operator.pipeline.cangjie",
					"match": "\\|>|~>"
				},
				{
					"name": "keyword.operator.range.cangjie",
					"match": "\\.\\.(=)?"
				},
				{
					"name": "keyword.operator.coalescing.cangjie",
					"match": "\\?\\?"
				},
				{
					"name": "keyword.operator.power.cangjie",
					"match": "\\*\\*=?"
				},
				{
					"name": "keyword.operator.comparison.cangjie",
					"match": "[!=]=|<=?|>=?"
				},
				{
					"name": "keyword.operator.logical.cangjie",
					"match": "&&=?|\\|\\|=?"
				},
				{
					"name": "keyword.operator.bitwise.cangjie",
					"match": "<<(=)?|>>(=)?|&(=)?|\\^(=)?|\\|(=)?"
				},
				{
					"name": "keyword.operator.arithmetic.cangjie",
					"match": "[+\\-*/%]=?"
				},
				{
					"name": "keyword.operator.assignment.cangjie",
					"match": "="
				},
				{
					"name": "keyword.operator.spread.cangjie",
					"match": "\\.\\.\\."
				},
				{
					"name": "keyword.operator.increment-decrement.cangjie",
					"match": "\\+\\+|--"
				},
				{
					"name": "keyword.operator.ternary.cangjie",
					"match": "[!~]"
				}
			]
		},

		"punctuation": {
			"patterns": [
				{
					"name": "punctuation.separator.comma.cangjie",
					"match": ","
				},
				{
					"name": "punctuation.terminator.semicolon.cangjie",
					"match": ";"
				},
				{
					"name": "punctuation.separator.colon.cangjie",
					"match": ":"
				},
				{
					"name": "punctuation.section.braces.begin.cangjie",
					"match": "\\{"
				},
				{
					"name": "punctuation.section.braces.end.cangjie",
					"match": "\\}"
				},
				{
					"name": "punctuation.section.parens.begin.cangjie",
					"match": "\\("
				},
				{
					"name": "punctuation.section.parens.end.cangjie",
					"match": "\\)"
				},
				{
					"name": "punctuation.section.brackets.begin.cangjie",
					"match": "\\["
				},
				{
					"name": "punctuation.section.brackets.end.cangjie",
					"match": "\\]"
				}
			]
		},

		"raw-identifiers": {
			"patterns": [
				{
					"name": "variable.other.raw.cangjie",
					"match": "`[a-zA-Z_]\\w*`"
				}
			]
		}
	}
}
